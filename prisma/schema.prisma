generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CoupleMemberRole {
  OWNER
  EDITOR
  VIEWER
}

enum CoupleVisibility {
  PUBLIC
  UNLISTED
  PRIVATE
}

enum NfcTagStatus {
  MANUFACTURED
  SOLD
  CLAIMED
  ACTIVE
  REVOKED
  LOST
}

enum OrderStatus {
  DRAFT
  PAID
  FULFILLED
  CANCELED
  REFUNDED
}

enum WidgetType {
  EVENT
  MEMORY
  TRACK
  CUSTOM
}

enum MediaAssetKind {
  IMAGE
  VIDEO
  AUDIO
  DRAWING
  OTHER
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String?
  avatarAssetId String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  coupleMembers CoupleMember[]
  orders        Order[]
  mediaAssets   MediaAsset[]   @relation("MediaAssetUploader")
  auditEvents   AuditEvent[]
}

model Couple {
  id              String           @id @default(cuid())
  publicSlug      String           @unique
  title           String?
  name1           String?
  name2           String?
  startDate       DateTime?
  themeKey        String           @default("sun-cycle")
  themeSettings   Json?
  visibility      CoupleVisibility @default(PUBLIC)
  publishedAt     DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  members         CoupleMember[]
  nfcTags         NfcTag[]
  widgets         Widget[]
  albumPhotos     AlbumPhoto[]
  drawingCanvases DrawingCanvas[]
  mediaAssets     MediaAsset[]
  scanEvents      ScanEvent[]
  auditEvents     AuditEvent[]
}

model CoupleMember {
  id        String           @id @default(cuid())
  coupleId  String
  userId    String
  role      CoupleMemberRole @default(EDITOR)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  couple    Couple           @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([coupleId, userId])
  @@index([userId])
}

model NfcTag {
  id             String       @id @default(cuid())
  publicCode     String       @unique
  activationCode String?      @unique
  status         NfcTagStatus @default(MANUFACTURED)
  orderId        String?
  coupleId       String?
  claimedAt      DateTime?
  activatedAt    DateTime?
  revokedAt      DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  order          Order?       @relation(fields: [orderId], references: [id], onDelete: SetNull)
  couple         Couple?      @relation(fields: [coupleId], references: [id], onDelete: SetNull)
  scanEvents     ScanEvent[]

  @@index([status])
  @@index([coupleId])
  @@index([orderId])
}

model Order {
  id               String      @id @default(cuid())
  orderNumber      String      @unique
  email            String
  status           OrderStatus @default(DRAFT)
  customerUserId   String?
  totalAmountCents Int?
  currency         String      @default("RUB")
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  customerUser     User?       @relation(fields: [customerUserId], references: [id], onDelete: SetNull)
  nfcTags          NfcTag[]

  @@index([email])
  @@index([customerUserId])
}

model Widget {
  id        String     @id @default(cuid())
  coupleId  String
  type      WidgetType
  title     String?
  body      String?
  startsAt  DateTime?
  sortOrder Int        @default(0)
  settings  Json?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  couple    Couple     @relation(fields: [coupleId], references: [id], onDelete: Cascade)

  @@index([coupleId, sortOrder])
}

model AlbumPhoto {
  id           String     @id @default(cuid())
  coupleId     String
  mediaAssetId String
  caption      String?
  sortOrder    Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  couple       Couple     @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  mediaAsset   MediaAsset @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)

  @@index([coupleId, sortOrder])
  @@index([mediaAssetId])
}

model DrawingCanvas {
  id           String      @id @default(cuid())
  coupleId     String
  title        String?
  mediaAssetId String?
  snapshotData Json?
  sortOrder    Int         @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  couple       Couple      @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  mediaAsset   MediaAsset? @relation(fields: [mediaAssetId], references: [id], onDelete: SetNull)

  @@index([coupleId, sortOrder])
  @@index([mediaAssetId])
}

model MediaAsset {
  id              String          @id @default(cuid())
  coupleId        String?
  uploadedById    String?
  kind            MediaAssetKind  @default(IMAGE)
  storageKey      String          @unique
  publicUrl       String?
  mimeType        String?
  sizeBytes       Int?
  width           Int?
  height          Int?
  metadata        Json?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  couple          Couple?         @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  uploadedBy      User?           @relation("MediaAssetUploader", fields: [uploadedById], references: [id], onDelete: SetNull)
  albumPhotos     AlbumPhoto[]
  drawingCanvases DrawingCanvas[]

  @@index([coupleId])
  @@index([uploadedById])
}

model ScanEvent {
  id        String   @id @default(cuid())
  nfcTagId  String?
  coupleId  String?
  ipHash    String?
  userAgent String?
  referer   String?
  country   String?
  city      String?
  createdAt DateTime @default(now())
  nfcTag    NfcTag?  @relation(fields: [nfcTagId], references: [id], onDelete: SetNull)
  couple    Couple?  @relation(fields: [coupleId], references: [id], onDelete: SetNull)

  @@index([nfcTagId, createdAt])
  @@index([coupleId, createdAt])
}

model AuditEvent {
  id          String   @id @default(cuid())
  actorUserId String?
  coupleId    String?
  action      String
  entityType  String?
  entityId    String?
  metadata    Json?
  createdAt   DateTime @default(now())
  actorUser   User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  couple      Couple?  @relation(fields: [coupleId], references: [id], onDelete: SetNull)

  @@index([actorUserId, createdAt])
  @@index([coupleId, createdAt])
}
